{
  "name": "chat-interfaces",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:widget": "vite build --config vite.widget.config.ts",
    "lint": "oxlint",
    "preview": "vite preview",
    "preview:widget": "vite preview --config vite.widget.config.ts",
    "prepare": "husky",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "oxlint --fix --max-warnings=0"
  }
}
